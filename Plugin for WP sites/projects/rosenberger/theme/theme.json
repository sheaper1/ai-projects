{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "960px",
			"wideSize": "1200px"
		},
		"color": {
			"custom": false,
			"customGradient": false,
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{ "slug": "base", "name": "Фон", "color": "#ffffff" },
				{ "slug": "contrast", "name": "Текст", "color": "#111111" },
				{ "slug": "primary", "name": "Акцент", "color": "#2563eb" },
				{ "slug": "secondary", "name": "Вторичный фон", "color": "#f3f4f6" }
			]
		},
		"typography": {
			"fluid": true,
			"customFontSize": false,
			"fontFamilies": [
				{
					"slug": "body",
					"name": "Основной",
					"fontFamily": "'Roboto Flex', system-ui, sans-serif"
				},
				{
					"slug": "heading",
					"name": "Заголовочный",
					"fontFamily": "'Nunito Sans', Georgia, serif"
				}
			],
			"fontSizes": [
				{ "slug": "small", "name": "S", "size": "0.875rem", "fluid": false },
				{ "slug": "medium", "name": "M", "size": "1.125rem", "fluid": { "min": "1rem", "max": "1.125rem" } },
				{ "slug": "large", "name": "L", "size": "1.5rem", "fluid": { "min": "1.25rem", "max": "1.5rem" } },
				{ "slug": "x-large", "name": "XL", "size": "2.5rem", "fluid": { "min": "1.75rem", "max": "2.5rem" } },
				{ "slug": "xx-large", "name": "XXL", "size": "3.5rem", "fluid": { "min": "2.25rem", "max": "3.5rem" } }
			]
		},
		"spacing": {
			"units": [ "px", "rem", "%", "vw", "vh" ],
			"spacingScale": { "steps": 0 },
			"spacingSizes": [
				{ "slug": "30", "name": "S", "size": "1rem" },
				{ "slug": "40", "name": "M", "size": "1.5rem" },
				{ "slug": "50", "name": "L", "size": "2rem" },
				{ "slug": "60", "name": "XL", "size": "3rem" },
				{ "slug": "70", "name": "XXL", "size": "4rem" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"lineHeight": "1.2"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--base)"
				}
			}
		}
	}
}
