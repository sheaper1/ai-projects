{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "864px",
			"wideSize": "1344px"
		},
		"color": {
			"custom": false,
			"customDuotone": false,
			"customGradient": false,
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{ "slug": "base", "name": "Base", "color": "#ffffff" },
				{ "slug": "contrast", "name": "Contrast", "color": "#142335" },
				{ "slug": "primary", "name": "Primary", "color": "#142335" },
				{ "slug": "accent", "name": "Accent", "color": "#decec4" },
				{ "slug": "surface", "name": "Surface", "color": "#f8f5f3" },
				{ "slug": "surface-muted", "name": "Surface muted", "color": "#f1f2f3" },
				{ "slug": "muted", "name": "Muted text", "color": "#747c86" },
				{ "slug": "border", "name": "Border", "color": "#b2b3b7" },
				{ "slug": "placeholder", "name": "Media placeholder", "color": "#969696" },
				{ "slug": "on-dark", "name": "Text on dark", "color": "#ffffff" }
			]
		},
		"typography": {
			"fluid": true,
			"customFontSize": false,
			"dropCap": false,
			"fontFamilies": [
				{
					"slug": "body",
					"name": "Roboto Flex",
					"fontFamily": "'Roboto Flex', Arial, sans-serif"
				},
				{
					"slug": "heading",
					"name": "Nunito Sans",
					"fontFamily": "'Nunito Sans', Arial, sans-serif"
				}
			],
			"fontSizes": [
				{ "slug": "r-12", "name": "12", "size": "0.75rem", "fluid": false },
				{ "slug": "r-14", "name": "14", "size": "0.875rem", "fluid": false },
				{ "slug": "r-16", "name": "16", "size": "1rem", "fluid": false },
				{ "slug": "r-18", "name": "18", "size": "1.125rem", "fluid": false },
				{ "slug": "r-20", "name": "20", "size": "1.25rem", "fluid": { "min": "1.125rem", "max": "1.25rem" } },
				{ "slug": "r-24", "name": "24", "size": "1.5rem", "fluid": { "min": "1.25rem", "max": "1.5rem" } },
				{ "slug": "r-32", "name": "32", "size": "2rem", "fluid": { "min": "1.625rem", "max": "2rem" } },
				{ "slug": "r-40", "name": "40", "size": "2.5rem", "fluid": { "min": "2rem", "max": "2.5rem" } },
				{ "slug": "r-48", "name": "48", "size": "3rem", "fluid": { "min": "2.25rem", "max": "3rem" } },
				{ "slug": "r-56", "name": "56", "size": "3.5rem", "fluid": { "min": "2.5rem", "max": "3.5rem" } },
				{ "slug": "r-64", "name": "64", "size": "4rem", "fluid": { "min": "2.75rem", "max": "4rem" } },
				{ "slug": "r-80", "name": "80", "size": "5rem", "fluid": { "min": "2.75rem", "max": "5rem" } },
				{ "slug": "r-96", "name": "96", "size": "6rem", "fluid": { "min": "3rem", "max": "6rem" } }
			]
		},
		"spacing": {
			"customSpacingSize": false,
			"units": [ "px", "rem", "%", "vw", "vh" ],
			"spacingScale": { "steps": 0 },
			"spacingSizes": [
				{ "slug": "r-4", "name": "4", "size": "0.25rem" },
				{ "slug": "r-8", "name": "8", "size": "0.5rem" },
				{ "slug": "r-16", "name": "16", "size": "1rem" },
				{ "slug": "r-24", "name": "24", "size": "1.5rem" },
				{ "slug": "r-32", "name": "32", "size": "2rem" },
				{ "slug": "r-40", "name": "40", "size": "2.5rem" },
				{ "slug": "r-48", "name": "48", "size": "3rem" },
				{ "slug": "r-64", "name": "64", "size": "4rem" },
				{ "slug": "r-section", "name": "Section", "size": "clamp(5rem, 10vw, 9.375rem)" }
			]
		},
		"custom": {
			"layout": {
				"gutter": "clamp(1.25rem, 3.333vw, 3rem)",
				"heroContent": "724px",
				"sectionSpace": "var(--wp--preset--spacing--r-section)"
			},
			"radius": {
				"small": "0.5rem",
				"medium": "1rem",
				"large": "1.5rem",
				"pill": "999px"
			},
			"transition": {
				"fast": "160ms ease",
				"base": "240ms ease"
			},
			"thirdParty": {
				"googleBlue": "#4285f4",
				"googleGold": "#fbbc04"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--r-24)",
			"padding": {
				"left": "var(--wp--custom--layout--gutter)",
				"right": "var(--wp--custom--layout--gutter)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--r-16)",
			"fontWeight": "400",
			"lineHeight": "1.5"
		},
		"elements": {
			"heading": {
				"color": { "text": "var(--wp--preset--color--contrast)" },
				"spacing": { "margin": { "top": "0", "bottom": "var(--wp--preset--spacing--r-24)" } },
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "400",
					"letterSpacing": "-0.03em",
					"lineHeight": "1.05"
				}
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--r-80)" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--r-40)" } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--r-24)", "lineHeight": "1.2" } },
			"h4": { "typography": { "fontSize": "var(--wp--preset--font-size--r-20)", "lineHeight": "1.25" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--contrast)" },
				"typography": { "textDecoration": "none" }
			},
			"button": {
				"border": { "radius": "var(--wp--custom--radius--pill)", "width": "0" },
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--on-dark)"
				},
				"spacing": {
					"padding": {
						"top": "0.875rem",
						"right": "1.75rem",
						"bottom": "0.875rem",
						"left": "1.75rem"
					}
				},
				"typography": { "fontSize": "var(--wp--preset--font-size--r-16)", "fontWeight": "500", "lineHeight": "1" }
			}
		},
		"blocks": {
			"core/group": { "spacing": { "blockGap": "var(--wp--preset--spacing--r-24)" } },
			"core/paragraph": { "spacing": { "margin": { "top": "0", "bottom": "var(--wp--preset--spacing--r-16)" } } },
			"core/navigation": { "typography": { "fontSize": "var(--wp--preset--font-size--r-16)", "fontWeight": "500" } },
			"core/separator": { "color": { "background": "var(--wp--preset--color--border)" } }
		}
	}
}
