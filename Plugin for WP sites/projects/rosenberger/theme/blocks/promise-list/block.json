{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "library/promise-list",
	"title": "Promise List",
	"category": "theme",
	"description": "Two-column: heading on the left, numbered list of promises with dividers on the right.",
	"supports": { "html": false, "inserter": true },
	"attributes": {
		"heading": { "type": "string", "default": "" },
		"items": {
			"type": "array",
			"default": [],
			"items": { "type": "object" }
		}
	},
	"editorScript": "file:./build/index.js",
	"style": "file:./build/style-index.css",
	"render": "file:./render.php"
}
