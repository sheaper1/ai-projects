{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "library/bio-hero",
	"title": "Bio Hero",
	"category": "theme",
	"description": "Split hero: label, name, job title and bio text on the left; portrait photo on the right.",
	"supports": { "html": false, "inserter": true },
	"attributes": {
		"label":       { "type": "string", "default": "Über mich" },
		"name":        { "type": "string", "default": "" },
		"jobTitle":    { "type": "string", "default": "" },
		"bio":         { "type": "string", "default": "" },
		"imageId":     { "type": "number", "default": 0 },
		"imageUrl":    { "type": "string", "default": "" },
		"nameCredit":  { "type": "string", "default": "Alexander<br>Rosenberger" }
	},
	"editorScript": "file:./build/index.js",
	"style": "file:./build/style-index.css",
	"render": "file:./render.php"
}
