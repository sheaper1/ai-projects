{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "library/testimonials",
  "title": "Testimonials (Google)",
  "category": "design",
  "description": "Отзывы Google (из плагина grw): заголовок + карточки (аватар, имя, дата, звёзды, текст). Данные динамические.",
  "keywords": ["testimonials", "отзывы", "google", "reviews"],
  "supports": { "html": false, "align": ["full"], "multiple": true },
  "attributes": {
    "heading":       { "type": "string",  "default": "Das sagen Menschen," },
    "headingItalic": { "type": "string",  "default": "die mit mir gearbeitet haben" },
    "limit":         { "type": "integer", "default": 9 },
    "minRating":     { "type": "integer", "default": 4 }
  },
  "editorScript": "file:./build/index.js",
  "viewScript":   "file:./view.js",
  "style":        "file:./build/style-index.css",
  "render":       "file:./render.php"
}
