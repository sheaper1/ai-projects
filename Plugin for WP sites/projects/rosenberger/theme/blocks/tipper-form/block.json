{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "library/tipper-form",
  "title": "Tipper Form",
  "category": "design",
  "description": "Секция «Tipp einsenden» — многошаговая воронка + скрытая WPForms-форма.",
  "keywords": ["form", "tipp", "wpforms", "funnel"],
  "supports": { "html": false, "align": ["full"], "multiple": false },
  "attributes": {
    "heading":    { "type": "string",  "default": "Ihre kostenlose Bewertung <em>anfragen</em>" },
    "lead":       { "type": "string",  "default": "In unter einer Minute. Ich melde mich danach persönlich bei Ihnen." },
    "formSlug":   { "type": "string",  "default": "tippgeber" },
    "wpformsId":  { "type": "integer", "default": 0 }
  },
  "editorScript": "file:./build/index.js",
  "style":        "file:./build/style-index.css",
  "render":       "file:./render.php"
}
