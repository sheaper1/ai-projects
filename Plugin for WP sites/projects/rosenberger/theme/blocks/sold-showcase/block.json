{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "library/sold-showcase",
	"title": "Sold Showcase",
	"category": "design",
	"icon": "format-image",
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "full" ],
		"multiple": false
	},
	"attributes": {
		"heading":      { "type": "string", "default": "Erfolgreich verkauft" },
		"headingItalic":{ "type": "string", "default": "in Vorarlberg" },
		"ctaText":      { "type": "string", "default": "Alle Referenzen ansehen" },
		"ctaUrl":       { "type": "string", "default": "/objekte/" },
		"navNextId":    { "type": "number", "default": 0 },
		"navNextUrl":   { "type": "string", "default": "" },
		"navPrevId":    { "type": "number", "default": 0 },
		"navPrevUrl":   { "type": "string", "default": "" }
	},
	"editorScript": "file:./build/index.js",
	"viewScript":   "file:./view.js",
	"style":        "file:./build/style-index.css",
	"render":       "file:./render.php"
}
