{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "library/tipper-types",
  "title": "Tipper Types",
  "category": "design",
  "description": "«Wer als Tippgeber in Frage kommt» — заголовок слева + 2 фото-карточки справа.",
  "keywords": ["tipper", "types", "who"],
  "supports": { "html": false, "align": ["full"], "multiple": false },
