{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "library/hero",
	"version": "0.1.0",
	"title": "Hero",
	"category": "design",
	"icon": "cover-image",
	"description": "Первый экран: заголовок, подзаголовок и кнопки. Контент редактируется, макет заблокирован.",
	"keywords": [ "hero", "первый экран", "обложка", "cover" ],
	"textdomain": "library",
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ],
		"spacing": {
			"padding": true,
			"margin": [ "top", "bottom" ],
			"blockGap": true
		},
		"color": {
			"background": true,
			"text": true,
			"gradients": true
		}
	},
	"editorScript": "file:./build/index.js",
	"style": "file:./build/style-index.css",
	"render": "file:./render.php"
}
