{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "library/region-services",
	"title": "Region Services",
	"category": "design",
	"icon": "screenoptions",
	"description": "Секция услуг региона: заголовок + кнопка + 3 карточки (иконка, заголовок, текст, «Erfahren Sie mehr →»).",
	"keywords": [ "region", "services", "leistungen", "cards" ],
	"supports": { "html": false, "align": [ "full" ], "multiple": true },
	"attributes": {
		"heading": { "type": "string", "default": "Womit ich Sie unterstütze" },
		"buttonText": { "type": "string", "default": "Kostenlos beraten lassen" },
		"buttonUrl": { "type": "string", "default": "/kontakt/" },
		"items": { "type": "array", "default": [] }
	},
	"editorScript": "file:./build/index.js",
	"style": "file:./build/style-index.css",
	"render": "file:./render.php"
}
