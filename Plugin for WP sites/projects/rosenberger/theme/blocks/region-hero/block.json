{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "library/region-hero",
	"title": "Region Hero",
	"category": "design",
	"icon": "location-alt",
	"description": "Hero страницы региона: «Immobilienmakler in {Ort}» + подзаголовок, кнопка, фото.",
	"keywords": [ "region", "hero", "makler", "ort" ],
	"supports": { "html": false, "align": [ "full" ], "multiple": false },
	"usesContext": [ "postId" ],
	"attributes": {
		"headingPrefix": { "type": "string", "default": "Immobilienmakler in" }
	},
	"editorScript": "file:./build/index.js",
	"style": "file:./build/style-index.css",
	"render": "file:./render.php"
}
