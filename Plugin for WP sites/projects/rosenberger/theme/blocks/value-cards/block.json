{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "library/value-cards",
	"title": "Value Cards",
	"category": "theme",
	"description": "Three horizontal feature cards: SVG icon, heading, description. Repeater.",
	"supports": { "html": false, "inserter": true },
	"attributes": {
		"cards": {
			"type": "array",
			"default": [],
			"items": { "type": "object" }
		}
	},
	"editorScript": "file:./build/index.js",
	"style": "file:./build/style-index.css",
	"render": "file:./render.php"
}
