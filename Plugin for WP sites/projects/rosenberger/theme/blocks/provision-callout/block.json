{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "library/provision-callout",
  "title": "Provision Callout",
  "category": "design",
  "description": "Секция «10%» с фоновым изображением и большим процентом.",
  "keywords": ["provision", "percent", "callout"],
  "supports": { "html": false, "align": ["full"], "multiple": false },
  "attributes": {
    "label":       { "type": "string",  "default": "Ihre Provision" },
    "value":       { "type": "string",  "default": "10 %" },
    "subtitle":    { "type": "string",  "default": "" },
    "finePrint":   { "type": "string",  "default": "" },
    "imageId":     { "type": "integer", "default": 0 },
    "imageUrl":    { "type": "string",  "default": "" }
  },
  "editorScript": "file:./build/index.js",
  "style":        "file:./build/style-index.css",
  "render":       "file:./render.php"
}
