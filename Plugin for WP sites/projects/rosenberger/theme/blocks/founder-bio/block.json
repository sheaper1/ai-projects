{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "library/founder-bio",
	"title": "Founder Bio",
	"category": "theme",
	"description": "Two-column: text content on the left (heading + paragraphs), tall portrait photo on the right.",
	"supports": { "html": false, "inserter": true },
	"attributes": {
		"heading":    { "type": "string", "default": "" },
		"paragraphs": { "type": "array", "default": [], "items": { "type": "string" } },
		"imageId":    { "type": "number", "default": 0 },
		"imageUrl":   { "type": "string", "default": "" }
	},
	"editorScript": "file:./build/index.js",
	"style": "file:./build/style-index.css",
	"render": "file:./render.php"
}
