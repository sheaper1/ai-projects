{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "library/blog-hero",
	"title": "Blog Hero",
	"category": "design",
	"icon": "welcome-write-blog",
	"description": "Заголовок блога + крупная карточка последней статьи.",
	"keywords": [ "blog", "hero", "neuigkeiten", "featured" ],
	"supports": { "html": false, "align": [ "full" ], "multiple": false },
	"attributes": {
		"eyebrow": { "type": "string", "default": "Aktuelles" },
		"headingItalic": { "type": "string", "default": "Neuigkeiten" },
		"heading": { "type": "string", "default": "rund um Immobilien" }
	},
	"editorScript": "file:./build/index.js",
	"style": "file:./build/style-index.css",
	"render": "file:./render.php"
}
