{
	"name": "wp-blocks-library",
	"version": "0.1.0",
	"private": true,
	"description": "Эталонная библиотека динамических блоков Gutenberg для веб-агентства.",
	"scripts": {
		"build": "wp-scripts build --webpack-src-dir=library/blocks/hero/src --output-path=library/blocks/hero/build",
		"start": "wp-scripts start --webpack-src-dir=library/blocks/hero/src --output-path=library/blocks/hero/build"
	},
	"devDependencies": {
		"@wordpress/scripts": "^30.0.0"
	}
}
