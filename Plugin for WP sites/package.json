{
	"name": "wp-blocks-library",
	"version": "0.1.0",
	"private": true,
	"description": "Эталонная библиотека динамических блоков Gutenberg для веб-агентства.",
	"scripts": {
		"build:hero": "wp-scripts build --webpack-src-dir=library/blocks/hero/src --output-path=library/blocks/hero/build",
		"build:hero-cover": "wp-scripts build --webpack-src-dir=library/blocks/hero-cover/src --output-path=library/blocks/hero-cover/build",
		"build": "npm run build:hero && npm run build:hero-cover",
		"start:hero-cover": "wp-scripts start --webpack-src-dir=library/blocks/hero-cover/src --output-path=library/blocks/hero-cover/build"
	},
	"devDependencies": {
		"@wordpress/scripts": "^30.0.0",
		"puppeteer": "^25.1.0",
		"sharp": "^0.35.2"
	}
}
