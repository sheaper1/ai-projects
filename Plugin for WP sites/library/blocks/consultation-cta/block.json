{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "library/consultation-cta",
	"title": "Consultation CTA",
	"category": "design",
	"icon": "cover-image",
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "full" ],
		"multiple": false
	},
	"attributes": {
		"heading": { "type": "string", "default": "Ihr kostenloses" },
		"headingItalic": { "type": "string", "default": "Erstgespräch" },
		"text": { "type": "string", "default": "Persönlich und völlig unverbindlich." },
		"buttonText": { "type": "string", "default": "Kostenlos beraten lassen" },
		"buttonUrl": { "type": "string", "default": "#" },
		"backgroundId": { "type": "number", "default": 0 },
		"backgroundUrl": { "type": "string", "default": "" }
	},
	"editorScript": "file:./build/index.js",
	"style": "file:./build/style-index.css",
	"render": "file:./render.php"
}
