{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "library/trust-bar",
	"version": "0.1.0",
	"title": "Trust Bar",
	"category": "design",
	"icon": "star-filled",
	"description": "Полоса доверия с рейтингом Google и преимуществами.",
	"textdomain": "library",
	"supports": { "html": false, "align": [ "full" ], "multiple": false },
	"attributes": {
		"badgeUrl": { "type": "string", "default": "" },
		"badgeId": { "type": "number", "default": 0 },
		"rating": { "type": "string", "default": "4.5" },
		"items": { "type": "array", "default": [ "Persönlich von mir betreut", "Schnelle Rückmeldung", "Vor Ort in ganz Vorarlberg" ] }
	},
	"editorScript": "file:./build/index.js",
	"style": "file:./build/style-index.css",
	"render": "file:./render.php"
}
