{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "library/property-catalog",
	"title": "Property Catalog",
	"category": "design",
	"icon": "building",
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "full" ]
	},
	"attributes": {
		"align":         { "type": "string", "default": "full" },
		"layout":        { "type": "string", "default": "compact" },
		"postsPerPage":  { "type": "number", "default": 9 },
		"archiveUrl":    { "type": "string", "default": "/alle-immobilien/" },
		"heading":       { "type": "string", "default": "Aktuelle Objekte" },
		"headingItalic": { "type": "string", "default": "in Vorarlberg" },
		"subtext":       { "type": "string", "default": "" }
	},
	"editorScript": "file:./build/index.js",
	"viewScript":   "file:./view.js",
	"style":        "file:./build/style-index.css",
	"render":       "file:./render.php"
}
