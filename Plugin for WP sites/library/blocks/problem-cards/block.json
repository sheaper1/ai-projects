{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "library/problem-cards",
  "title": "Problem Cards",
  "category": "design",
  "description": "Заголовок + вводный абзац сверху и ряд карточек-проблем с иконкой на бежевом кружке.",
  "keywords": ["pain", "problem", "cards", "row"],
  "supports": { "html": false, "align": ["full"], "multiple": true },
  "attributes": {
    "heading":       { "type": "string", "default": "" },
    "headingItalic": { "type": "string", "default": "" },
    "intro":         { "type": "string", "default": "" },
    "items":         { "type": "array",  "default": [] }
  },
  "editorScript": "file:./build/index.js",
  "style":        "file:./build/style-index.css",
  "render":       "file:./render.php"
}
