      <p class="wm-fine" data-wm-reveal>Free to enter · No purchase necessary · 18+ · This promotion is not sponsored, endorsed or administered by Instagram. <a href="#" style="text-decoration:underline">Terms apply</a></p>
    </div>
  </header>

  <section class="wm-section" id="prizes">
    <div class="wm-wrap">
      <div class="wm-prizes-head">
        <span class="wm-eyebrow" data-wm-reveal>What you can win</span>
        <h2 style="margin-top:.8rem" data-wm-reveal>Two ways to <span class="wm-ital">win Mallorca</span></h2>
      </div>
      <div class="wm-prize-grid">
        <article class="wm-prize" data-wm-reveal style="background-image:url('https://mallorcadistillery.com/cdn/shop/files/Frame_261.jpg?width=1200')">
