{% comment %}theme-check-disable RemoteAsset{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Libre+Caslon+Text:ital,wght@0,400;1,400&display=swap" rel="stylesheet">

<style>
  #shopify-section-{{ section.id }} .win-mallorca {
    --ink: #162F53;
    --ink-2: #5B6976;
    --subtle: #9AA3AD;
    --line: #E6E3DC;
    --bg: #FFFFFF;
    --bg-soft: #F4F2ED;
    --mint: #E7ECE6;
    --gold: #FAD380;
    --gold-deep: #B68C39;
    --navy-deep: #0F2138;
    --ital: 'Libre Caslon Text', Georgia, serif;
    --max: 80rem;
    background: var(--bg);
    color: var(--ink);
    font-family: 'Montserrat', sans-serif;
    line-height: 1.5;
    letter-spacing: -0.01em;
    overflow: hidden;
    -webkit-font-smoothing: antialiased;
  }

  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }}.shopify-section,
  #shopify-section-{{ section.id }}.win-mallorca-section {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }

  body:has(#shopify-section-{{ section.id }} .win-mallorca) main,
  body:has(#shopify-section-{{ section.id }} .win-mallorca) #main-content,
  body:has(#shopify-section-{{ section.id }} .win-mallorca) .main-content {
    padding-top: 0 !important;
  }

  #shopify-section-{{ section.id }} .win-mallorca *,
  #shopify-section-{{ section.id }} .win-mallorca *::before,
  #shopify-section-{{ section.id }} .win-mallorca *::after { box-sizing: border-box; }
  #shopify-section-{{ section.id }} .win-mallorca img { display: block; max-width: 100%; }
  #shopify-section-{{ section.id }} .win-mallorca a { color: inherit; text-decoration: none; }
  #shopify-section-{{ section.id }} .win-mallorca button,
  #shopify-section-{{ section.id }} .win-mallorca input { font: inherit; }

  #shopify-section-{{ section.id }} .wm-wrap { max-width: var(--max); margin: 0 auto; padding: 0 2.5rem; }
  #shopify-section-{{ section.id }} .wm-section { padding: 6rem 0; }
  #shopify-section-{{ section.id }} .wm-eyebrow { color: var(--subtle); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; }
  #shopify-section-{{ section.id }} .wm-ital { font-family: var(--ital); font-style: italic; font-weight: 400; letter-spacing: -0.01em; }
  #shopify-section-{{ section.id }} .win-mallorca h1,
  #shopify-section-{{ section.id }} .win-mallorca h2,
  #shopify-section-{{ section.id }} .win-mallorca h3 { margin: 0; color: var(--ink); font-weight: 500; line-height: 1.04; letter-spacing: -0.03em; }
  #shopify-section-{{ section.id }} .win-mallorca h1 { font-size: clamp(2.8rem, 6vw, 5rem); }
  #shopify-section-{{ section.id }} .win-mallorca h2 { font-size: clamp(2rem, 3.6vw, 3rem); }
  #shopify-section-{{ section.id }} .wm-lead { color: var(--ink-2); font-size: 1.08rem; font-weight: 400; line-height: 1.65; }

  #shopify-section-{{ section.id }} .wm-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border: 0;
    border-radius: 999px;
    background: var(--gold);
    color: var(--navy-deep) !important;
    padding: 0.95rem 1.8rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s, transform 0.3s;
  }
  #shopify-section-{{ section.id }} .wm-btn:hover { background: #F2C25A; transform: translateY(-1px); }

  #shopify-section-{{ section.id }} .wm-entry { display: flex; gap: 0.5rem; width: 100%; max-width: 30rem; }
  #shopify-section-{{ section.id }} .wm-entry input {
    flex: 1;
    border: 1px solid transparent;
    border-radius: 999px;
    outline: 0;
    background: #fff;
    color: var(--ink);
    padding: 0.95rem 1.2rem;
    font-size: 0.95rem;
  }
  #shopify-section-{{ section.id }} .wm-entry input:focus-visible { border-color: var(--gold); }
  #shopify-section-{{ section.id }} .wm-fine { margin-top: 0.9rem; color: var(--subtle); font-size: 0.72rem; letter-spacing: 0.01em; }

  #shopify-section-{{ section.id }} .wm-hero-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; align-items: center; }
  #shopify-section-{{ section.id }} .wm-btn-ig {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border-radius: 999px;
    background: #fff;
    color: var(--navy-deep) !important;
    padding: 0.95rem 1.7rem;
    font-size: 0.95rem;
    font-weight: 600;
    transition: transform 0.3s;
  }
  #shopify-section-{{ section.id }} .wm-btn-ig:hover { transform: translateY(-1px); }
  #shopify-section-{{ section.id }} .wm-btn-ig svg { width: 19px; height: 19px; }
  #shopify-section-{{ section.id }} .wm-btn-line {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid rgba(255,255,255,0.34);
    border-radius: 999px;
    color: #fff !important;
    padding: 0.95rem 1.6rem;
    font-size: 0.95rem;
    font-weight: 500;
    transition: background-color 0.3s, color 0.3s;
  }
  #shopify-section-{{ section.id }} .wm-btn-line:hover { background: #fff; color: var(--navy-deep) !important; }
  #shopify-section-{{ section.id }} .wm-hashtag { display: inline-block; margin-top: 1.2rem; color: var(--gold); font-family: var(--ital); font-size: 1.25rem; font-style: italic; }

  #shopify-section-{{ section.id }} .wm-hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    background-image: url('https://mallorcadistillery.com/cdn/shop/files/Frame_260.jpg?width=1800');
    background-size: cover;
    background-position: center;
  }
  #shopify-section-{{ section.id }} .wm-hero::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(15,33,56,0.35), rgba(15,33,56,0.82)); }
  #shopify-section-{{ section.id }} .wm-hero-in { position: relative; z-index: 1; width: 100%; max-width: var(--max); margin: 0 auto; padding: 6rem 2.5rem; color: #fff; }
  #shopify-section-{{ section.id }} .wm-hero-in h1 { max-width: 18ch; color: #fff; }
  #shopify-section-{{ section.id }} .wm-hero-in h1 .wm-ital { color: var(--gold); }
  #shopify-section-{{ section.id }} .wm-badge { display: inline-block; margin-bottom: 1.4rem; border: 1px solid rgba(255,255,255,0.2); border-radius: 999px; background: rgba(255,255,255,0.12); color: #fff; padding: 0.5rem 1.1rem; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.06em; }
  #shopify-section-{{ section.id }} .wm-hero-sub { max-width: 34rem; margin: 1.2rem 0 2rem; color: rgba(255,255,255,0.85); font-size: 1.12rem; font-weight: 400; line-height: 1.6; }
  #shopify-section-{{ section.id }} .wm-hero-in .wm-fine { color: rgba(255,255,255,0.6); }

  #shopify-section-{{ section.id }} .wm-prizes-head { max-width: 42rem; margin: 0 auto 3rem; text-align: center; }
  #shopify-section-{{ section.id }} .wm-prize-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 1.6rem; }
  #shopify-section-{{ section.id }} .wm-prize {
    position: relative;
    min-height: 26rem;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    border-radius: 1.25rem;
    background-size: cover;
    background-position: center;
    color: #fff;
  }
  #shopify-section-{{ section.id }} .wm-prize::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(15,33,56,0.05), rgba(15,33,56,0.78)); }
  #shopify-section-{{ section.id }} .wm-prize-body { position: relative; z-index: 1; padding: 2.2rem; }
  #shopify-section-{{ section.id }} .wm-prize-tag { display: inline-block; margin-bottom: 1rem; border-radius: 999px; background: var(--gold); color: var(--navy-deep); padding: 0.4rem 1rem; font-size: 0.66rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  #shopify-section-{{ section.id }} .wm-prize h3 { color: #fff; font-size: 2rem; }
  #shopify-section-{{ section.id }} .wm-prize h3 .wm-ital { color: var(--gold); }
  #shopify-section-{{ section.id }} .wm-prize p { max-width: 26rem; margin-top: 0.6rem; color: rgba(255,255,255,0.85); font-size: 0.95rem; line-height: 1.6; }

  #shopify-section-{{ section.id }} .wm-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 3rem; }
  #shopify-section-{{ section.id }} .wm-step { border-top: 2px solid var(--ink); padding-top: 1.3rem; }
  #shopify-section-{{ section.id }} .wm-step-num { margin-bottom: 0.6rem; color: var(--gold-deep); font-family: var(--ital); font-size: 2.2rem; font-style: italic; line-height: 1; }
  #shopify-section-{{ section.id }} .wm-step-name { margin-bottom: 0.4rem; font-size: 1.05rem; font-weight: 600; }
  #shopify-section-{{ section.id }} .wm-step-desc { color: var(--ink-2); font-size: 0.88rem; line-height: 1.6; }

  #shopify-section-{{ section.id }} .wm-wall { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.7rem; margin-top: 3rem; }
  #shopify-section-{{ section.id }} .wm-entries-title {
    font-size: clamp(1.65rem, 3vw, 2.45rem);
    line-height: 1.05;
  }
  #shopify-section-{{ section.id }} .wm-entries-title .wm-ital {
    font-size: inherit;
  }
  #shopify-section-{{ section.id }} .wm-wall-item { position: relative; overflow: hidden; border-radius: 0.6rem; background: var(--mint); padding-top: 100%; }
  #shopify-section-{{ section.id }} .wm-wall-item img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  #shopify-section-{{ section.id }} .wm-wall-item::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 60%, rgba(15,33,56,0.25)); }
  #shopify-section-{{ section.id }} .wm-wall-tag { position: absolute; z-index: 1; left: 0.7rem; bottom: 0.6rem; color: #fff; font-size: 0.66rem; letter-spacing: 0.04em; opacity: 0.9; }

  #shopify-section-{{ section.id }} .wm-col-head { max-width: 42rem; margin: 0 auto 3rem; text-align: center; }
  #shopify-section-{{ section.id }} .wm-col-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.4rem; }
  #shopify-section-{{ section.id }} .wm-col-card { display: flex; flex-direction: column; text-align: center; }
  #shopify-section-{{ section.id }} .wm-cc-img { position: relative; overflow: hidden; border-radius: 0.6rem; background: var(--mint); padding-top: 118%; }
  #shopify-section-{{ section.id }} .wm-cc-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; padding: 1.4rem; }
  #shopify-section-{{ section.id }} .wm-cc-name { margin: 0.9rem 0 0.15rem; font-size: 1.05rem; font-weight: 600; }
  #shopify-section-{{ section.id }} .wm-cc-meta { color: var(--subtle); font-size: 0.78rem; }

  #shopify-section-{{ section.id }} .wm-cta { background: var(--ink); color: #fff; text-align: center; }
  #shopify-section-{{ section.id }} .wm-cta h2 { color: #fff; }
  #shopify-section-{{ section.id }} .wm-cta h2 .wm-ital { color: var(--gold); }
  #shopify-section-{{ section.id }} .wm-cta p { max-width: 32rem; margin: 0.8rem auto 0; color: rgba(255,255,255,0.66); }
  #shopify-section-{{ section.id }} .wm-cta .wm-entry { justify-content: center; margin: 1.8rem auto 0; }
  #shopify-section-{{ section.id }} .wm-cta .wm-entry input { border-color: rgba(255,255,255,0.13); }
  #shopify-section-{{ section.id }} .wm-cta .wm-fine { color: rgba(255,255,255,0.5); text-align: center; }

  #shopify-section-{{ section.id }} [data-wm-reveal] { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; transition-delay: var(--wm-delay, 0ms); }
  #shopify-section-{{ section.id }} [data-wm-reveal].is-visible { opacity: 1; transform: translateY(0); }
  #shopify-section-{{ section.id }} .win-mallorca a:focus-visible,
  #shopify-section-{{ section.id }} .win-mallorca button:focus-visible,
  #shopify-section-{{ section.id }} .win-mallorca input:focus-visible { outline: 2px solid var(--gold-deep); outline-offset: 3px; }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} [data-wm-reveal] { opacity: 1 !important; transform: none !important; transition-duration: 0.001ms !important; }
  }

  @media (max-width: 991px) {
    #shopify-section-{{ section.id }} .wm-wrap { padding-left: 1.5rem; padding-right: 1.5rem; }
    #shopify-section-{{ section.id }} .wm-section { padding: 4rem 0; }
    #shopify-section-{{ section.id }} .wm-prize-grid,
    #shopify-section-{{ section.id }} .wm-steps { grid-template-columns: 1fr; gap: 1.4rem; }
    #shopify-section-{{ section.id }} .wm-wall,
    #shopify-section-{{ section.id }} .wm-col-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    #shopify-section-{{ section.id }} .win-mallorca { font-size: 15px; }
    #shopify-section-{{ section.id }} .wm-entries-title {
      max-width: 22rem;
      margin-left: auto !important;
      margin-right: auto !important;
      text-align: center;
      font-size: 1.62rem !important;
      line-height: 1.08;
    }
    #shopify-section-{{ section.id }} .wm-entries-title .wm-ital {
      display: block;
      width: max-content;
      max-width: 100%;
      margin: 0.15rem auto 0;
      font-size: 1.48rem !important;
    }
    #shopify-section-{{ section.id }} .wm-entry { flex-direction: column; }
    #shopify-section-{{ section.id }} .wm-entry input,
    #shopify-section-{{ section.id }} .wm-entry .wm-btn { border-radius: 0.7rem; }
    #shopify-section-{{ section.id }} .wm-hero-in { padding: 4rem 1.5rem; }
  }
</style>

<div class="win-mallorca">
  <header class="wm-hero">
    <div class="wm-hero-in">
