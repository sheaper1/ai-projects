<script>
(() => {
  const section = document.getElementById('shopify-section-{{ section.id }}');
  if (!section || section.dataset.palmaVodkaV3 === 'true') return;
  section.dataset.palmaVodkaV3 = 'true';

  if (section.querySelector('.elfsight-sapp-cff8a79b-9ce9-4e16-9940-5f54ea0cffda') && !document.querySelector('script[data-pv-elfsight]')) {
    const elfsightScript = document.createElement('script');
    elfsightScript.src = 'https://shy.elfsight.com/p/platform.js?shop=mallorcadistillerypalmagin.myshopify.com';
    elfsightScript.async = true;
    elfsightScript.dataset.pvElfsight = 'true';
    document.head.appendChild(elfsightScript);
  }

  const accordions = section.querySelectorAll('[data-accordion]');
  accordions.forEach((accordion) => {
    const heading = accordion.querySelector('[data-accordion-toggle]');
    const text = accordion.querySelector('.pv-accordion-text');
    if (!heading) return;

    heading.setAttribute('role', 'button');
    heading.setAttribute('tabindex', '0');
    heading.setAttribute('aria-expanded', String(accordion.classList.contains('is-open')));

    const open = () => {
      heading.setAttribute('aria-expanded', 'true');
      accordion.classList.add('is-open');
      if (!text) return;
      text.style.maxHeight = `${text.scrollHeight}px`;
      const done = (event) => {
        if (event.propertyName !== 'max-height') return;
        text.style.maxHeight = 'none';
        text.removeEventListener('transitionend', done);
      };
      text.addEventListener('transitionend', done);
    };

    const close = () => {
      heading.setAttribute('aria-expanded', 'false');
      if (text) {
        text.style.maxHeight = `${text.scrollHeight}px`;
        void text.offsetHeight;
        text.style.maxHeight = '0px';
      }
      accordion.classList.remove('is-open');
    };

    const toggle = () => accordion.classList.contains('is-open') ? close() : open();
    heading.addEventListener('click', toggle);
    heading.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' && event.key !== ' ') return;
      event.preventDefault();
      toggle();
    });
  });

  const thumbs = Array.from(section.querySelectorAll('[data-gthumb]'));
  const mains = Array.from(section.querySelectorAll('[data-gmain]'));
  const activateImage = (index) => {
    thumbs.forEach((thumb) => {
      const active = Number(thumb.dataset.gthumb) === index;
      thumb.classList.toggle('is-active', active);
      thumb.setAttribute('aria-selected', String(active));
    });
    mains.forEach((image) => image.classList.toggle('is-active', Number(image.dataset.gmain) === index));
  };
  thumbs.forEach((thumb) => {
    thumb.addEventListener('click', () => activateImage(Number(thumb.dataset.gthumb)));
  });

  const revealItems = Array.from(section.querySelectorAll('[data-reveal], [data-split]'));
  if (!('IntersectionObserver' in window) || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    revealItems.forEach((item) => item.classList.add('is-visible'));
    return;
  }

  revealItems.forEach((item, index) => {
    item.style.setProperty('--pv-delay', `${(index % 4) * 70}ms`);
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      entry.target.classList.add('is-visible');
      observer.unobserve(entry.target);
    });
  }, {
    threshold: 0.12,
    rootMargin: '0px 0px -8% 0px'
  });

  requestAnimationFrame(() => {
    revealItems.forEach((item) => observer.observe(item));
  });
})();
</script>

